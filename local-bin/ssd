#!/usr/bin/env bash

set -euo pipefail

function check_ssd_path() {
    SSD_PATH="${0}"
    if [[ "${SSD_PATH}" == "${HOME}/.local/bin/ssd" ]]; then
        SSD_PATH="ssd"
    fi
}

function err() {
    echo "❌ ${1}" >&2
}

function chromium_copy_paste() {
    while [[ $# -gt 0 ]]; do
        case "${1:-}" in
        --help | help | -h)
            usage_browser
            exit 0
            ;;
        *)
            err "Unknown option: ${1:-}"
            usage_browser
            exit 1
            ;;
        esac
    done

    cat <<EOF | pbcopy
var allowPaste = function(e){
  e.stopImmediatePropagation();
  return true;
};

document.addEventListener('paste', allowPaste, true);
EOF

    echo "✅ Copied code to clipboard!"
    echo "ℹ️  Press '⌘ + ⌥ + I' on a browser to open 'Developer Tools' go to 'Console' and paste the code in clipboard."
}

function find_dump_dir() {
    DUMP_DIR="$(find "${HOME}/code" -maxdepth 4 -type d -name "dump" -print -quit 2>/dev/null)"
    if [[ -z "${DUMP_DIR}" ]]; then
        err "Could not find 'dump' directory under ${HOME}/code"
        exit 1
    fi
}

function usage_dump() {
    echo "🛠️ Usage: ${SSD_PATH} dump [Options] [topic]"
    echo ""
    echo "Options:"
    echo "    --format, -f <format>   Specify the format for the dump file (default: sh)"
    echo "    --open, -o              Open the dump directory in VS Code"
    echo "    --help, -h              Show this help message"
    echo ""
    echo "Arguments:"
    echo "    topic                   Optional short description appended to the filename"
}

function usage_gl() {
    echo "🛠️ Usage: ${SSD_PATH} gl <url> [Options]"
    echo ""
    echo "Add a URL to GoodLinks for later reading."
    echo ""
    echo "Options:"
    echo "    --title, -t <title>         Link title (max 200 chars)"
    echo "    --summary, -s <summary>     Link summary (max 400 chars)"
    echo "    --tags <tag1,tag2,...>      Comma-separated tags"
    echo "    --starred                   Mark the link as starred"
    echo "    --read                      Mark the link as read"
    echo "    --help, -h                  Show this help message"
}

function usage_browser() {
    echo "🛠️ Usage: ${SSD_PATH} browser"
    echo ""
    echo "Force a website to allow copy-paste in Chromium-based browsers."
    echo "Copies a JavaScript snippet to clipboard that re-enables paste events."
}

function usage_password() {
    echo "🛠️ Usage: ${SSD_PATH} password [Options] [length]"
    echo ""
    echo "Generate a random password and copy it to the clipboard."
    echo ""
    echo "Options:"
    echo "    --help, -h    Show this help message"
    echo ""
    echo "Arguments:"
    echo "    length         Password length (default: 20)"
}

function generate_password() {
    local length=20

    while [[ $# -gt 0 ]]; do
        case "${1:-}" in
        --help | help | -h)
            usage_password
            exit 0
            ;;
        *)
            if [[ "${1}" =~ ^- ]]; then
                err "Unknown option: ${1:-}"
                usage_password
                exit 1
            fi
            length="${1}"
            shift
            ;;
        esac
    done

    local password
    password=$(tr </dev/urandom -dc 'A-Za-z0-9!@#$%&*_-' | head -c "${length}" || true)
    echo -n "${password}" | pbcopy
    echo "Generated password: ${password}"
    echo "✅ Password also copied to clipboard!"
}

function goodlinks() {
    local url=""
    local title=""
    local summary=""
    local tags=""
    local starred="false"
    local read_status="false"

    # First positional arg is the URL
    if [[ $# -gt 0 && ! "${1}" =~ ^- ]]; then
        url="${1}"
        shift
    fi

    while [[ $# -gt 0 ]]; do
        case "${1:-}" in
        --title | -t)
            shift
            title="${1}"
            shift
            ;;
        --summary | -s)
            shift
            summary="${1}"
            shift
            ;;
        --tags)
            shift
            tags="${1}"
            shift
            ;;
        --starred)
            shift
            starred="true"
            ;;
        --read)
            shift
            read_status="true"
            ;;
        --help | help | -h)
            usage_gl
            exit 0
            ;;
        *)
            err "Unknown option: ${1:-}"
            usage_gl
            exit 1
            ;;
        esac
    done

    # Validate URL
    if [[ -z "${url}" ]]; then
        err "URL is required"
        usage_gl
        exit 1
    fi

    if [[ ! "${url}" =~ ^https?:// ]]; then
        err "URL must start with http:// or https://"
        exit 1
    fi

    # Validate title length
    if [[ -n "${title}" && ${#title} -gt 200 ]]; then
        err "Title must be 200 characters or less (got ${#title})"
        exit 1
    fi

    # Validate summary length
    if [[ -n "${summary}" && ${#summary} -gt 400 ]]; then
        err "Summary must be 400 characters or less (got ${#summary})"
        exit 1
    fi

    # Build JSON payload with jq
    local json
    json=$(jq -n \
        --arg url "${url}" \
        --arg title "${title}" \
        --arg summary "${summary}" \
        --arg tags "${tags}" \
        --argjson starred "${starred}" \
        --argjson read "${read_status}" \
        '{url: $url} +
        (if $title != "" then {title: $title} else {} end) +
        (if $summary != "" then {summary: $summary} else {} end) +
        (if $tags != "" then {tags: ($tags | split(","))} else {} end) +
        (if $starred then {starred: true} else {} end) +
        (if $read then {read: true} else {} end)')

    # POST to GoodLinks API
    local response
    local http_code
    response=$(curl --silent --output /dev/stderr --write-out "%{http_code}" \
        -X POST \
        -H "Content-Type: application/json" \
        -d "${json}" \
        "http://localhost:9428/api/v1/links" 2>/dev/null) || {
        err "Failed to connect to GoodLinks. Is the app running?"
        exit 1
    }
    http_code="${response}"

    if [[ "${http_code}" =~ ^2 ]]; then
        echo "✅ Link added to GoodLinks: ${url}"
    else
        err "GoodLinks API returned HTTP ${http_code}"
        exit 1
    fi
}

function dump() {
    find_dump_dir
    local dump_format="sh"
    local dump_topic=""

    while [[ $# -gt 0 ]]; do
        case "${1:-}" in
        " ")
            shift
            ;;
        --format | -f)
            shift
            dump_format="$1"
            shift
            ;;
        --open | -o)
            shift
            code "${DUMP_DIR}"
            exit 0
            ;;
        --help | help | -h)
            usage_dump
            exit 0
            ;;
        *)
            if [[ "${1}" =~ ^- ]]; then
                err "Unknown option: ${1:-}"
                usage_dump
                exit 1
            fi
            if [[ -n "${dump_topic}" ]]; then
                dump_topic="${dump_topic}-${1}"
            else
                dump_topic="${1}"
            fi
            shift
            ;;
        esac
    done

    FILE_PATH="${DUMP_DIR}/$(date +%Y)-archives/$(date "+%Y-%m-%b-%d-%H-%M-%S")${dump_topic:+-${dump_topic}}.${dump_format}"

    code "${DUMP_DIR}"
    mkdir -p "$(dirname "${FILE_PATH}")"
    touch "${FILE_PATH}"
    code "${FILE_PATH}"
}

function usage_global() {
    echo "🛠️ Usage: ${SSD_PATH} <subcommand> [options]"
    echo ""
    echo "Available subcommands:"
    echo "    dump                Create a dump file"
    echo "    date                Print the current date in a specific format: YYYY-MM-mmm-dd-HH-MM-SS"
    echo "    goodlinks, gl       Add a URL to GoodLinks"
    echo "    browser             Force a website to allow copy-paste in Chromium-based browsers"
    echo "    password, pass      Generate a random password and copy to clipboard"
    echo "    help, --help, -h    Show this help message"
}

check_ssd_path

case "${1:-}" in
dump)
    shift
    dump "$@"
    ;;
date)
    shift
    date "+%Y-%m-%b-%d-%H-%M-%S"
    ;;
browser)
    shift
    chromium_copy_paste "$@"
    ;;
gl | goodlinks)
    shift
    goodlinks "$@"
    ;;
password | pass)
    shift
    generate_password "$@"
    ;;
help | --help | -h)
    usage_global
    exit 0
    ;;
*)
    err "Unknown subcommand: ${1:-}"
    usage_global
    exit 1
    ;;
esac
