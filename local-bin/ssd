#!/usr/bin/env bash

set -euo pipefail

function check_ssd_path() {
    SSD_PATH="${0}"
    if [[ "${SSD_PATH}" == "${HOME}/.local/bin/ssd" ]]; then
        SSD_PATH="ssd"
    fi
}

function err() {
    echo "❌ ${1}" >&2
}

function chromium_copy_paste() {
    cat <<EOF | pbcopy
var allowPaste = function(e){
  e.stopImmediatePropagation();
  return true;
};

document.addEventListener('paste', allowPaste, true);
EOF

    echo "✅ Copied code to clipboard!"
    echo "ℹ️  Press '⌘ + ⌥ + I' on a browser to open 'Developer Tools' go to 'Console' and paste the code in clipboard."
}

function find_dump_dir() {
    DUMP_DIR="$(find "${HOME}/code" -maxdepth 4 -type d -name "dump" -print -quit 2>/dev/null)"
    if [[ -z "${DUMP_DIR}" ]]; then
        err "Could not find 'dump' directory under ${HOME}/code"
        exit 1
    fi
}

function usage_dump() {
    echo "🛠️ Usage: ${SSD_PATH} dump [Options] [topic]"
    echo ""
    echo "Options:"
    echo "    --format, -f <format>   Specify the format for the dump file (default: sh)"
    echo "    --open, -o              Open the dump directory in VS Code"
    echo "    --help, -h              Show this help message"
    echo ""
    echo "Arguments:"
    echo "    topic                   Optional short description appended to the filename."
    echo "                            If omitted, an interactive prompt will ask for it (press Enter to skip)."
}

function dump() {
    find_dump_dir
    local dump_format="sh"
    local dump_topic=""


    while [[ $# -gt 0 ]]; do
        case "${1:-}" in
        " ")
            shift
            ;;
        --format | -f)
            shift
            dump_format="$1"
            shift
            ;;
        --open | -o)
            shift
            code "${DUMP_DIR}"
            exit 0
            ;;
        --help | help | -h)
            usage_dump
            exit 0
            ;;
        *)
            if [[ "${1:-}" == -* ]]; then
                err "Unknown option: ${1:-}"
                usage_dump
                exit 1
            fi
            dump_topic="${1:-}"
            shift
            ;;
        esac
    done

    if [[ -z "${dump_topic}" ]] && [[ -t 0 ]]; then
        read -rp "Enter topic (press Enter to skip): " dump_topic
    fi

    local dump_timestamp
    dump_timestamp="$(date "+%Y-%m-%b-%d-%H-%M-%S")"
    local dump_year="${dump_timestamp:0:4}"
    local dump_suffix="${dump_topic:+-${dump_topic}}"
    FILE_PATH="${DUMP_DIR}/${dump_year}-archives/${dump_timestamp}${dump_suffix}.${dump_format}"

    code "${DUMP_DIR}"
    touch "${FILE_PATH}"
    code "${FILE_PATH}"
}

function usage_global() {
    echo "🛠️ Usage: ${SSD_PATH} <subcommand> [options]"
    echo ""
    echo "Available subcommands:"
    echo "    dump      Create a dump file"
    echo "    date      Print the current date in a specific format: YYYY-MM-mmm-dd-HH-MM-SS"
    echo "    browser   Force a website to allow copy-paste in Chromium-based browsers"
}

check_ssd_path

case "${1:-}" in
dump)
    shift
    dump "$@"
    ;;
date)
    shift
    date "+%Y-%m-%b-%d-%H-%M-%S"
    ;;
browser)
    shift
    chromium_copy_paste
    ;;
*)
    err "Unknown subcommand: ${1:-}"
    usage_global
    exit 1
    ;;
esac
