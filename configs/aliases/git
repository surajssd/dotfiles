# git related aliases

alias gs="git status"
alias gcmt="git commit -s -S "
alias gl="git log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit"
alias grba="git rebase -S -i --autosquash "
alias gca="git commit --amend --no-edit -S "
alias grbm="git rebase -S -i"

function gcm() {
    local default_branch
    default_branch=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null)
    default_branch=${default_branch#origin/}
    if [[ -z "$default_branch" ]]; then
        echo "❌ Could not determine origin's default branch (run: git remote set-head origin -a)" >&2
        return 1
    fi
    git checkout "$default_branch"
}

function gpum() {
    local branch
    branch=$(git branch --show-current)
    if [[ -z "$branch" ]]; then
        echo "❌ Not on a branch (detached HEAD?)" >&2
        return 1
    fi
    git pull --ff upstream "$branch"
}

function gpom() {
    local branch
    branch=$(git branch --show-current)
    if [[ -z "$branch" ]]; then
        echo "❌ Not on a branch (detached HEAD?)" >&2
        return 1
    fi
    git pull --ff origin "$branch"
}

# Inspired by: https://github.com/jsturtevant/dotfiles/blob/main/aliases/gitalias
wt() {
    # Portable prompt+read: zsh's `read` has no -p flag, so print first.
    _wt_prompt() {
        printf '%s' "$1" >&2
        read "$2"
    }

    if ! git diff --quiet || ! git diff --cached --quiet; then
        echo "You have uncommitted changes."
        _wt_prompt "Stash changes before switching? (y/N) " confirm
        if [[ "$confirm" =~ ^[Yy]$ ]]; then
            git stash push -m "Auto-stash before wt switch"
        else
            echo "Aborting."
            return 1
        fi
    fi

    local dir
    if command -v fzf >/dev/null 2>&1; then
        dir=$(git worktree list | fzf --height=50% --reverse \
            --preview 'git -C {1} log --oneline -10' \
            --preview-window=right:35% | awk '{print $1}')
    else
        # Fallback when fzf is not installed: numbered menu selection.
        # Avoid shell-specific array indexing so this works in both bash and zsh.
        local list count choice
        list=$(git worktree list)
        if [[ -z "$list" ]]; then
            echo "No worktrees found."
            return 1
        fi
        count=$(printf '%s\n' "$list" | wc -l | tr -d ' ')
        printf '%s\n' "$list" | nl -w3 -s') '
        _wt_prompt "Select worktree (1-${count}): " choice
        if ! [[ "$choice" =~ ^[0-9]+$ ]] || ((choice < 1 || choice > count)); then
            echo "Invalid selection."
            return 1
        fi
        dir=$(printf '%s\n' "$list" | sed -n "${choice}p" | awk '{print $1}')
    fi
    [[ -n "$dir" ]] && cd "$dir"
}

# Create a new worktree with a new branch and cd into it
wta() {
    local branch_name="$1"

    if [[ -z "$branch_name" ]]; then
        echo "Usage: wta <branch-name>"
        echo "Creates a new worktree with a new branch and changes into it."
        return 1
    fi

    # Check if we're in a git repository
    if ! git rev-parse --git-dir > /dev/null 2>&1; then
        echo "Error: Not in a git repository"
        return 1
    fi

    # Check if branch already exists
    if git show-ref --verify --quiet "refs/heads/$branch_name"; then
        echo "Error: Branch '$branch_name' already exists"
        return 1
    fi

    local current_dir_name
    current_dir_name="$(basename "$PWD")"
    # Sanitize branch name for the directory (replace slashes with dashes)
    local sanitized_branch_name="${branch_name//\//-}"
    local worktree_dir="../${current_dir_name}-${sanitized_branch_name}"

    # Check if worktree directory already exists
    if [[ -d "$worktree_dir" ]]; then
        echo "Error: Directory '$worktree_dir' already exists"
        return 1
    fi

    echo "Creating worktree '$worktree_dir' with new branch '$branch_name'..."
    if git worktree add -b "$branch_name" "$worktree_dir"; then
        cd "$worktree_dir" || return 1
        echo "Now in: $(pwd)"
        echo "Branch: $(git branch --show-current)"
    else
        echo "Failed to create worktree"
        return 1
    fi
}
