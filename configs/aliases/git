# git related aliases
# This file is sourced by both bash and zsh; lint it as bash.
# shellcheck shell=bash

alias gs="git status"
alias gcmt="git commit -s -S "
alias gl="git log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit"
alias grba="git rebase -S -i --autosquash "
alias gca="git commit --amend --no-edit -S "
alias grbm="git rebase -S -i"

function gcm() {
    local default_branch
    default_branch=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null)
    default_branch=${default_branch#origin/}
    if [[ -z "$default_branch" ]]; then
        echo "❌ Could not determine origin's default branch (run: git remote set-head origin -a)" >&2
        return 1
    fi
    git checkout "$default_branch"
}

function gpum() {
    local branch
    branch=$(git branch --show-current)
    if [[ -z "$branch" ]]; then
        echo "❌ Not on a branch (detached HEAD?)" >&2
        return 1
    fi
    git pull --ff upstream "$branch"
}

function gpom() {
    local branch
    branch=$(git branch --show-current)
    if [[ -z "$branch" ]]; then
        echo "❌ Not on a branch (detached HEAD?)" >&2
        return 1
    fi
    git pull --ff origin "$branch"
}

# Inspired by: https://github.com/jsturtevant/dotfiles/blob/main/aliases/gitalias
wt() {
    # Portable prompt+read: zsh's `read` has no -p flag, so print first.
    _wt_prompt() {
        printf '%s' "$1" >&2
        read -r "$2"
    }

    # Assigned indirectly by _wt_prompt via `read "$2"`, which shellcheck
    # cannot trace; declaring it local mirrors `choice` below.
    local confirm
    if ! git diff --quiet || ! git diff --cached --quiet; then
        echo "You have uncommitted changes."
        _wt_prompt "Stash changes before switching? (y/N) " confirm
        if [[ "$confirm" =~ ^[Yy]$ ]]; then
            git stash push -m "Auto-stash before wt switch"
        else
            echo "Aborting."
            return 1
        fi
    fi

    local dir
    if command -v fzf >/dev/null 2>&1; then
        dir=$(git worktree list | fzf --height=50% --reverse \
            --preview 'git -C {1} log --oneline -10' \
            --preview-window=right:35% | awk '{print $1}')
    else
        # Fallback when fzf is not installed: numbered menu selection.
        # Avoid shell-specific array indexing so this works in both bash and zsh.
        local list count choice
        list=$(git worktree list)
        if [[ -z "$list" ]]; then
            echo "No worktrees found."
            return 1
        fi
        count=$(printf '%s\n' "$list" | wc -l | tr -d ' ')
        printf '%s\n' "$list" | nl -w3 -s') '
        _wt_prompt "Select worktree (1-${count}): " choice
        if ! [[ "$choice" =~ ^[0-9]+$ ]] || ((choice < 1 || choice > count)); then
            echo "Invalid selection."
            return 1
        fi
        dir=$(printf '%s\n' "$list" | sed -n "${choice}p" | awk '{print $1}')
    fi
    if [[ -n "$dir" ]]; then
        cd "$dir" || return 1
    fi
}

# Create a new worktree with a new branch and cd into it
wta() {
    local branch_name="$1"

    if [[ -z "$branch_name" ]]; then
        echo "Usage: wta <branch-name>"
        echo "Creates a new worktree with a new branch and changes into it."
        return 1
    fi

    # Check if we're in a git repository
    if ! git rev-parse --git-dir >/dev/null 2>&1; then
        echo "Error: Not in a git repository"
        return 1
    fi

    # Check if branch already exists
    if git show-ref --verify --quiet "refs/heads/$branch_name"; then
        echo "Error: Branch '$branch_name' already exists"
        return 1
    fi

    local current_dir_name
    current_dir_name="$(basename "$PWD")"
    # Sanitize branch name for the directory (replace slashes with dashes)
    local sanitized_branch_name="${branch_name//\//-}"
    local worktree_dir="../${current_dir_name}-${sanitized_branch_name}"

    # Check if worktree directory already exists
    if [[ -d "$worktree_dir" ]]; then
        echo "Error: Directory '$worktree_dir' already exists"
        return 1
    fi

    echo "Creating worktree '$worktree_dir' with new branch '$branch_name'..."
    if git worktree add -b "$branch_name" "$worktree_dir"; then
        cd "$worktree_dir" || return 1
        echo "Now in: $(pwd)"
        echo "Branch: $(git branch --show-current)"
    else
        echo "Failed to create worktree"
        return 1
    fi
}

# Create a worktree from an open PR (interactive fzf picker) and cd into it
wtpr() {
    if ! command -v gh >/dev/null 2>&1; then
        echo "❌ GitHub CLI (gh) is required for wtpr" >&2
        return 1
    fi
    if ! command -v fzf >/dev/null 2>&1; then
        echo "❌ fzf is required for wtpr" >&2
        return 1
    fi
    if ! git rev-parse --git-dir >/dev/null 2>&1; then
        echo "❌ Not in a git repository" >&2
        return 1
    fi

    # Pick an open PR. `column` aligns the number|branch|author: title fields so
    # fzf's {1} placeholder maps to the PR number for the preview.
    local pr
    pr=$(gh pr list --state open --json number,title,headRefName,author \
        --template '{{range .}}{{.number}}|{{.headRefName}}|{{.author.login}}: {{.title}}{{"\n"}}{{end}}' |
        column -t -s '|' |
        fzf --height=50% --reverse --header="Select PR to checkout as worktree" \
            --preview 'gh pr view {1} --comments=false' \
            --preview-window=right:40%)
    [[ -z "$pr" ]] && return 0

    local pr_number branch
    pr_number=$(echo "$pr" | awk '{print $1}')
    branch=$(echo "$pr" | awk '{print $2}')

    # Match wta's naming: ../<repo-dir>-<branch> with slashes sanitized.
    local current_dir_name safe_branch worktree_dir
    current_dir_name="$(basename "$PWD")"
    safe_branch="${branch//\//-}"
    worktree_dir="../${current_dir_name}-${safe_branch}"

    if [[ -d "$worktree_dir" ]]; then
        echo "❌ Directory '$worktree_dir' already exists" >&2
        return 1
    fi

    echo "⏳ Fetching PR #${pr_number} (${branch})..."

    # PRs filed against an "upstream" remote (fork workflow) expose
    # pull/N/head there; otherwise fall back to origin.
    local remote="origin"
    if git remote get-url upstream &>/dev/null &&
        git fetch upstream "pull/${pr_number}/head:${branch}" 2>/dev/null; then
        remote="upstream"
    elif ! git fetch origin "pull/${pr_number}/head:${branch}" 2>/dev/null; then
        echo "❌ Failed to fetch PR #${pr_number} from upstream or origin" >&2
        return 1
    fi

    if git worktree add "$worktree_dir" "$branch"; then
        cd "$worktree_dir" || return 1
        # Best-effort upstream tracking; for fork PRs the ref may not exist.
        git branch --set-upstream-to="${remote}/${branch}" "$branch" 2>/dev/null || true
        echo "✅ Worktree created at ${worktree_dir} on branch ${branch}"
        echo "ℹ️  Now in: $(pwd)"
    else
        echo "❌ Failed to create worktree for PR #${pr_number}" >&2
        return 1
    fi
}
